# Pawdar environment configuration
# Copy to .env in this directory and fill in values. Never commit .env.

# --- Database (XAMPP / local MySQL) ---
PAWDAR_DB_HOST=localhost
PAWDAR_DB_NAME=pawdar
PAWDAR_DB_USER=root
PAWDAR_DB_PASS=

# --- Resend (https://resend.com) — verification & password reset emails ---
RESEND_API_KEY=re_your_api_key_here
# Testing (no verified domain): only delivers to your Resend account email
RESEND_FROM="Pawdar <onboarding@resend.dev>"
# Production: verify your domain, then e.g. RESEND_FROM="Pawdar <noreply@yourdomain.com>"

# --- Playwright E2E (optional; playwright/.env can override) ---
BASE_URL=http://localhost/WS101_Aliwate/WS101-Pawdar/web
